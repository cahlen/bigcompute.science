---
import Base from '../../layouts/Base.astro';

const findings = await Astro.glob('../../content/findings/*.md');
const sorted = findings.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<Base title="Findings" description="Novel observations and discoveries from heavy computation">
  <h1 class="m-reveal">Findings</h1>
  <p class="m-reveal" style="color: var(--muted); margin-bottom: 1.5rem; font-size: 0.9rem; font-style: italic;">
    Each finding is peer-reviewed claim-by-claim against live academic literature. Badges show the <a href="/verification/" style="color: var(--accent);">certification level</a>.
  </p>

  <div class="experiments-list">
    {sorted.map((f) => (
      <a href={`/findings/${f.frontmatter.slug}/`} class="experiment-card">
        <div class="card-header">
          <time datetime={f.frontmatter.date}>
            {new Date(f.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
          {f.frontmatter.certification && (
            <span class={`cert-badge cert-${f.frontmatter.certification.level}`}
                  title={`${f.frontmatter.certification.verdict} by ${f.frontmatter.certification.reviewer} (${f.frontmatter.certification.date})`}>
              {f.frontmatter.certification.level === 'gold' ? 'GOLD' :
               f.frontmatter.certification.level === 'silver' ? 'SILVER' :
               f.frontmatter.certification.level === 'bronze' ? 'BRONZE' : '?'} Verified
            </span>
          )}
          {f.frontmatter.conjecture_year && (
            <span class="conjecture-age">Open for {2026 - f.frontmatter.conjecture_year} years</span>
          )}
        </div>
        <h3>{f.frontmatter.title}</h3>
        <p class="card-meta">{f.frontmatter.summary}</p>
        <div class="card-tags">
          {f.frontmatter.domain?.map((t: string) => <span class="tag tag-domain">{t}</span>)}
        </div>
      </a>
    ))}
  </div>
  <script is:inline>
  (function() {
    var reveals = document.querySelectorAll('.m-reveal');
    function onScroll() {
      var vh = window.innerHeight;
      for (var i = 0; i < reveals.length; i++) {
        var el = reveals[i];
        if (el.getBoundingClientRect().top < vh * 0.85) el.classList.add('visible');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
  </script>

  <style>
    .m-reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .m-reveal.visible { opacity: 1; transform: translateY(0); }
    h1 { font-family: var(--font-serif); letter-spacing: -0.03em; }
  </style>
</Base>
