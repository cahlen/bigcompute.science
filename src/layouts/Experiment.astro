---
import Base from './Base.astro';
import certData from '../data/certifications.json';

const { frontmatter } = Astro.props;
const { title, date, author, status, hardware, tags, results } = frontmatter;

// Look up full review data from manifest-derived certifications
const certEntry = certData.certifications.find((c: any) => c.slug === frontmatter.slug);
const certLevel = certEntry?.level ?? frontmatter.certification?.level ?? 'uncertified';
const certReviews = certEntry?.reviews ?? [];
const certNote = frontmatter.certification?.note ?? '';
const certRemediations = (certEntry as any)?.remediations ?? [];
const issuesFound = certEntry?.issues_found ?? 0;
const issuesResolved = certEntry?.issues_resolved ?? 0;
const reviewCount = certReviews.length;
const worstVerdict = certReviews.length > 0
  ? certReviews.reduce((worst: string, r: any) => {
      const order: Record<string, number> = { REJECT: 0, REVISE_AND_RESUBMIT: 1, ACCEPT_WITH_REVISION: 2, ACCEPT: 3 };
      return (order[r.verdict] ?? 2) < (order[worst] ?? 2) ? r.verdict : worst;
    }, certReviews[0].verdict)
  : frontmatter.certification?.verdict ?? '';
const modelsSummary = certEntry?.models_summary ?? frontmatter.certification?.reviewer ?? '';

// Math rendering for result values
function renderMath(s: string): string {
  const sup: any = {'0':'⁰','1':'¹','2':'²','3':'³','4':'⁴','5':'⁵','6':'⁶','7':'⁷','8':'⁸','9':'⁹','-':'⁻'};
  const toSup = (n: string) => [...n].map((c: string) => sup[c] || c).join('');
  let out = s;
  // Large bare integers → scientific notation (1000000000 → 10⁹)
  out = out.replace(/\b(\d{7,})\b/g, (_: string, num: string) => {
    const n = parseFloat(num);
    if (n === 0) return '0';
    const exp = Math.floor(Math.log10(n));
    const mantissa = n / Math.pow(10, exp);
    if (Math.abs(mantissa - 1) < 0.001) return '10' + toSup(String(exp));
    if (Math.abs(mantissa - Math.round(mantissa)) < 0.001) return Math.round(mantissa) + '×10' + toSup(String(exp));
    return mantissa.toFixed(1) + '×10' + toSup(String(exp));
  });
  // Explicit caret notation: 10^10 → 10¹⁰
  out = out.replace(/(\d+)\^(\d+)/g, (_: string, base: string, exp: string) => base + toSup(exp));
  // Scientific notation: 4.4e12 → 4.4×10¹²
  out = out.replace(/(\d+\.?\d*)[eE]\+?(\d+)/g, (_: string, m: string, exp: string) => m + '×10' + toSup(exp));
  // Symbols
  out = out.replace(/>=/g, '≥').replace(/<=/g, '≤').replace(/->/g, '→');
  // Add commas to remaining 4-6 digit numbers
  out = out.replace(/\b(\d{4,6})\b/g, (_: string, num: string) => parseInt(num).toLocaleString());
  return out;
}

const canonicalURL = `https://bigcompute.science/findings/${frontmatter.slug}/`;
const isoDate = new Date(date).toISOString().split('T')[0];
const summary = frontmatter.summary || '';
const codeURL = frontmatter.code || 'https://github.com/cahlen/idontknow';
const datasetURL = frontmatter.dataset || '';
const domains = frontmatter.domain || [];
---

<Base title={title} description={summary}>
  {/* Google Scholar: Highwire Press meta tags */}
  <Fragment slot="head">
    <meta name="citation_title" content={title} />
    <meta name="citation_author" content="Cahlen Humphreys" />
    <meta name="citation_publication_date" content={isoDate} />
    <meta name="citation_online_date" content={isoDate} />
    <meta name="citation_journal_title" content="bigcompute.science" />
    <meta name="citation_abstract" content={summary} />
    {codeURL && <meta name="citation_technical_report_institution" content="bigcompute.science" />}

    {/* Dublin Core metadata */}
    <meta name="DC.title" content={title} />
    <meta name="DC.creator" content="Cahlen Humphreys" />
    <meta name="DC.date" content={isoDate} />
    <meta name="DC.description" content={summary} />
    <meta name="DC.rights" content="CC BY 4.0" />
    <meta name="DC.type" content="Dataset" />
    {domains.map((d: string) => <meta name="DC.subject" content={d} />)}

    {/* JSON-LD: ScholarlyArticle for Google Scholar */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ScholarlyArticle",
      "headline": title,
      "abstract": summary,
      "datePublished": isoDate,
      "dateModified": isoDate,
      "author": {
        "@type": "Person",
        "name": "Cahlen Humphreys",
        "url": "https://github.com/cahlen",
        "sameAs": ["https://huggingface.co/cahlen", "https://www.linkedin.com/in/cahlenhu"]
      },
      "publisher": {
        "@type": "Organization",
        "name": "bigcompute.science",
        "url": "https://bigcompute.science"
      },
      "url": canonicalURL,
      "mainEntityOfPage": canonicalURL,
      "isAccessibleForFree": true,
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "about": domains.map((d: string) => ({ "@type": "Thing", "name": d })),
      ...(codeURL ? { "codeRepository": codeURL } : {}),
    })} />

    {/* JSON-LD: Dataset for Google Dataset Search */}
    {datasetURL && <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Dataset",
      "name": title,
      "description": summary,
      "url": canonicalURL,
      "creator": {
        "@type": "Person",
        "name": "Cahlen Humphreys",
        "url": "https://github.com/cahlen"
      },
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "distribution": {
        "@type": "DataDownload",
        "encodingFormat": "application/json",
        "contentUrl": datasetURL
      },
      "sameAs": datasetURL,
      "datePublished": isoDate,
      "keywords": domains,
    })} />}
  </Fragment>

  <article class="experiment">
    <div class="experiment-meta">
      <div class="meta-row">
        <time datetime={date}>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span class="author">by <a href={frontmatter.author_github}>{author}</a></span>
        {status && <span class={`status status-${status}`}>{status}</span>}
        {(certEntry || frontmatter.certification) && (
          <span class={`cert-badge cert-${certLevel}`}
                title={certNote}>
            {certLevel === 'gold' ? 'Gold' :
             certLevel === 'silver' ? 'Silver' :
             certLevel === 'bronze' ? 'Bronze' : '?'}
          </span>
        )}
      </div>

      {(certEntry || frontmatter.certification) && (
        <details class="cert-detail">
          <summary class="cert-detail-summary">
            <span class={`cert-badge cert-${certLevel}`}>
              {certLevel.toUpperCase()}
            </span>
            <span class="cert-summary-text">
              AI Literature Audit &middot; {reviewCount} review{reviewCount !== 1 ? 's' : ''}
            </span>
            <span class="cert-expand-hint">&darr;</span>
          </summary>
          <div class="cert-expanded">
            <table class="cert-table-inner">
              <tr>
                <td class="cert-label">Consensus</td>
                <td><code>{worstVerdict}</code></td>
              </tr>
              <tr>
                <td class="cert-label">Models</td>
                <td>{modelsSummary}</td>
              </tr>
              <tr>
                <td class="cert-label">Level</td>
                <td>
                  <span class={`cert-badge cert-${certLevel}`} style="font-size:0.65rem">
                    {certLevel.toUpperCase()}
                  </span>
                  {certLevel === 'gold' && ' \u2014 3+ published papers corroborate methods'}
                  {certLevel === 'silver' && ' \u2014 Published literature supports approach'}
                  {certLevel === 'bronze' && ' \u2014 Novel observation, limited literature precedent'}
                </td>
              </tr>
            </table>

            {certReviews.length > 0 && (
              <div class="cert-review-ledger">
                <h4 style="font-size:0.75rem;margin:0.8rem 0 0.4rem;color:var(--text-secondary)">Review Ledger</h4>
                {certReviews.map((r: any) => (
                  <div class="cert-review-row">
                    <span class="cert-review-date">{r.date}</span>
                    <span class="cert-review-model">{r.model}</span>
                    <span class="cert-review-provider">({r.provider})</span>
                    <span class={`cert-badge cert-${r.level || certLevel}`} style="font-size:0.55rem;padding:0.1rem 0.4rem">
                      {(r.level || certLevel).toUpperCase()}
                    </span>
                    <code class="cert-review-verdict">{r.verdict}</code>
                  </div>
                ))}
              </div>
            )}

            {certRemediations.length > 0 && (
              <div class="cert-remediations">
                <h4 style="font-size:0.75rem;margin:0.8rem 0 0.4rem;color:var(--text-secondary)">
                  Issues Identified ({issuesResolved}/{issuesFound} resolved)
                </h4>
                {certRemediations.map((r: any) => (
                  <div class={`cert-remediation-row cert-rem-${r.status}`}>
                    <span class={`cert-rem-severity cert-rem-sev-${r.severity}`}>{r.severity}</span>
                    <span class="cert-rem-desc">{r.description.length > 80 ? r.description.slice(0, 77) + '...' : r.description}</span>
                    {r.status === 'resolved' && r.commit ? (
                      <a href={`https://github.com/cahlen/bigcompute.science/commit/${r.commit}`}
                         target="_blank" class={`cert-rem-status cert-rem-st-${r.status}`}>
                        resolved
                      </a>
                    ) : (
                      <span class={`cert-rem-status cert-rem-st-${r.status}`}>{r.status}</span>
                    )}
                  </div>
                ))}
              </div>
            )}

            {certNote && (
              <div class="cert-note-box">
                <p>{certNote}</p>
              </div>
            )}

            <div class="cert-actions">
              <a href={`https://github.com/cahlen/idontknow/tree/main/docs/verifications`} target="_blank" class="cert-action-btn">All Reviews</a>
              <a href="/verification/" class="cert-action-btn">About Auditing</a>
              <a href="https://github.com/cahlen/idontknow/blob/main/docs/verifications/SCHEMA.md" target="_blank" class="cert-action-btn cert-action-contribute">Add Your Audit</a>
            </div>
          </div>
        </details>
      )}

      {hardware && (
        <div class="hardware-block">
          <h4>Hardware</h4>
          <div class="hardware-specs">
            <span class="spec">{hardware.gpus}</span>
            <span class="spec">{hardware.cpus}</span>
            <span class="spec">{hardware.ram} RAM</span>
          </div>
        </div>
      )}

      {tags && (
        <div class="tags">
          {tags.domain?.map((t: string) => <span class="tag tag-domain">{t}</span>)}
          {tags.hardware?.map((t: string) => <span class="tag tag-hw">{t}</span>)}
          {tags.method?.map((t: string) => <span class="tag tag-method">{t}</span>)}
        </div>
      )}

      {results && (
        <div class="results-summary">
          <h4>Key Results</h4>
          <dl>
            {Object.entries(results).map(([key, val]: [string, any]) => {
              if (val === null || val === undefined) return null;
              const label = key.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
              const raw = Array.isArray(val) ? val.join(', ') : String(val);
              const display = renderMath(raw);
              const isPass = (key === 'failures' && val === 0) || (key.includes('validation') && String(val).includes('PASS'));
              const isFail = key === 'failures' && val > 0;
              return (
                <><dt>{label}</dt><dd class={isPass ? 'result-pass' : isFail ? 'result-fail' : ''} set:html={display} /></>
              );
            })}
          </dl>
        </div>
      )}
    </div>

    <div class="experiment-content">
      <slot />
    </div>

    <div class="experiment-footer">
      {datasetURL && (
        <a href={datasetURL} class="data-link" target="_blank">Download Data on Hugging Face</a>
      )}
      {frontmatter.code && (
        <a href={frontmatter.code} class="code-link" target="_blank">View Code on GitHub</a>
      )}
    </div>
  </article>
</Base>
