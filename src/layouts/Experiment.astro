---
import Base from './Base.astro';

const { frontmatter } = Astro.props;
const { title, date, author, status, hardware, tags, results } = frontmatter;
---

<Base title={title}>
  <article class="experiment">
    <div class="experiment-meta">
      <div class="meta-row">
        <time datetime={date}>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span class="author">by <a href={frontmatter.author_github}>{author}</a></span>
        {status && <span class={`status status-${status}`}>{status}</span>}
        {frontmatter.certification && (
          <span class={`cert-badge cert-${frontmatter.certification.level}`}
                title={frontmatter.certification.note}>
            {frontmatter.certification.level === 'gold' ? 'GOLD' :
             frontmatter.certification.level === 'silver' ? 'SILVER' :
             frontmatter.certification.level === 'bronze' ? 'BRONZE' : '?'} Verified
          </span>
        )}
      </div>

      {frontmatter.certification && (
        <details class="cert-detail">
          <summary class="cert-detail-summary">
            <span class={`cert-badge cert-${frontmatter.certification.level}`}>
              {frontmatter.certification.level.toUpperCase()} Verified
            </span>
            <span class="cert-verdict">{frontmatter.certification.verdict}</span>
            <span class="cert-reviewer-inline">by {frontmatter.certification.reviewer}</span>
            <span class="cert-expand-hint">Click for peer review details</span>
          </summary>
          <div class="cert-expanded">
            <div class="cert-meta-row">
              <span class="cert-reviewer">Reviewer: {frontmatter.certification.reviewer}</span>
              <span class="cert-date">Date: {frontmatter.certification.date}</span>
            </div>
            <div class="cert-note-block">
              <strong>Review Summary:</strong>
              <p>{frontmatter.certification.note}</p>
            </div>
            <div class="cert-what-this-means">
              <strong>What this means:</strong>
              <p>
                {frontmatter.certification.level === 'gold' &&
                  '3+ peer-reviewed papers (zbMATH) corroborate the mathematical context. Methods validated against published benchmarks. Computational results are reproducible.'}
                {frontmatter.certification.level === 'silver' &&
                  '1+ peer-reviewed paper plus strong arXiv coverage support the approach. Methods are grounded in established literature.'}
                {frontmatter.certification.level === 'bronze' &&
                  'This is a novel computational observation. arXiv preprints exist on related topics, but no direct literature precedent for this specific finding.'}
              </p>
            </div>
            <div class="cert-how-it-works">
              <strong>How this review was conducted:</strong>
              <p>The reviewer used the <a href="https://mcp.bigcompute.science">bigcompute.science MCP server</a> to query arXiv, zbMATH, Semantic Scholar, and OEIS. Each numerical claim was checked against the papers found. The full claim-by-claim review is available as JSON.</p>
            </div>
            <div class="cert-actions">
              <a href={`https://github.com/cahlen/idontknow/blob/main/docs/verifications/${frontmatter.slug}_peer-review.json`} target="_blank" class="cert-action-btn">View Full Review (JSON)</a>
              <a href="/verification/" class="cert-action-btn">About Verification</a>
              <a href="https://github.com/cahlen/idontknow/blob/main/docs/verifications/SCHEMA.md" target="_blank" class="cert-action-btn cert-action-contribute">Submit Your Own Review</a>
            </div>
          </div>
        </details>
      )}

      {hardware && (
        <div class="hardware-block">
          <h4>Hardware</h4>
          <div class="hardware-specs">
            <span class="spec">{hardware.gpus}</span>
            <span class="spec">{hardware.cpus}</span>
            <span class="spec">{hardware.ram} RAM</span>
          </div>
        </div>
      )}

      {tags && (
        <div class="tags">
          {tags.domain?.map((t: string) => <span class="tag tag-domain">{t}</span>)}
          {tags.hardware?.map((t: string) => <span class="tag tag-hw">{t}</span>)}
          {tags.method?.map((t: string) => <span class="tag tag-method">{t}</span>)}
        </div>
      )}

      {results && (
        <div class="results-summary">
          <h4>Key Results</h4>
          <dl>
            {results.conjecture && <><dt>Conjecture</dt><dd>{results.conjecture}</dd></>}
            {results.verified_range && <><dt>Verified Range</dt><dd>d = {results.verified_range[0].toLocaleString()} to {results.verified_range[1].toLocaleString()}</dd></>}
            {results.failures !== undefined && <><dt>Failures</dt><dd class={results.failures === 0 ? 'result-pass' : 'result-fail'}>{results.failures}</dd></>}
            {results.llm_proofs && <><dt>LLM Proofs</dt><dd>{results.llm_proofs}</dd></>}
          </dl>
        </div>
      )}
    </div>

    <div class="experiment-content">
      <slot />
    </div>

    {frontmatter.code && (
      <div class="experiment-footer">
        <a href={frontmatter.code} class="code-link" target="_blank">View Code on GitHub</a>
      </div>
    )}
  </article>
</Base>
