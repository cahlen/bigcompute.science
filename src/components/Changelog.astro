---
// Pull recent git commits at build time
import { execSync } from 'child_process';

let entries: { date: string; message: string; hash: string }[] = [];

try {
  const log = execSync(
    'git log --pretty=format:"%h|%ad|%s" --date=format:"%b %d" -20',
    { encoding: 'utf-8', cwd: process.cwd() }
  );

  entries = log.trim().split('\n').map(line => {
    const [hash, date, ...msgParts] = line.split('|');
    return { hash, date, message: msgParts.join('|') };
  }).filter(e => {
    // Only show substantive updates, skip meta/style/infra commits
    const m = e.message.toLowerCase();
    return !m.includes('co-authored') &&
           !m.includes('merge') &&
           e.message.length > 10;
  }).slice(0, 8);
} catch (e) {
  // Build might not have git access (e.g., Cloudflare)
  entries = [];
}

// Classify commits by keywords
function getTag(msg: string): { label: string; cls: string } {
  const m = msg.toLowerCase();
  if (m.includes('finding') || m.includes('density') || m.includes('exception') || m.includes('convergence'))
    return { label: 'finding', cls: 'cl-finding' };
  if (m.includes('ramanujan') || m.includes('kronecker') || m.includes('class num') || m.includes('hausdorff'))
    return { label: 'experiment', cls: 'cl-experiment' };
  if (m.includes('peer review') || m.includes('verification') || m.includes('review') || m.includes('cert'))
    return { label: 'review', cls: 'cl-verification' };
  if (m.includes('mcp') || m.includes('deploy') || m.includes('tool'))
    return { label: 'infra', cls: 'cl-infra' };
  if (m.includes('hf') || m.includes('upload') || m.includes('dataset') || m.includes('model card'))
    return { label: 'data', cls: 'cl-data' };
  return { label: 'update', cls: 'cl-update' };
}
---

{entries.length > 0 && (
  <section class="changelog">
    <div class="changelog-inner">
      <h3>Recent Updates</h3>
      <div class="changelog-entries">
        {entries.map(e => {
          const tag = getTag(e.message);
          return (
            <div class="cl-entry">
              <time>{e.date}</time>
              <span class={`cl-tag ${tag.cls}`}>{tag.label}</span>
              <span class="cl-msg">{e.message.slice(0, 120)}{e.message.length > 120 ? '...' : ''}</span>
            </div>
          );
        })}
      </div>
    </div>
  </section>
)}
