---
import Base from '../layouts/Base.astro';

const experiments = await Astro.glob('../content/experiments/*.md');
const sorted = experiments.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

---

<Base title="Open Computational Mathematics on GPUs" description="Experimental results from heavy computation. Custom CUDA kernels, GPU clusters, big math, serious hardware.">
  <section class="hero">
    <h1 class="m-reveal">bigcompute<span>.science</span></h1>
    <p class="tagline m-reveal">Experimental results from heavy computation.</p>
    <p class="subtitle m-reveal">Open computational results from GPU-accelerated mathematical experiments.</p>
    <p class="subtitle agent-callout m-reveal">Human-readable. <a href="/llms.txt">Agent-consumable</a>. <a href="/verification/">Literature-audited</a>.</p>
  </section>

  <section class="experiments-list">
    <h2 class="m-reveal">Experiments</h2>
    {sorted.map((exp) => (
      <a href={`/experiments/${exp.frontmatter.slug}/`} class="experiment-card">
        <div class="card-top-row">
          <time datetime={exp.frontmatter.date}>
            {new Date(exp.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
          <div class="card-badges">
            {exp.frontmatter.status && (
              <span class={`status status-${exp.frontmatter.status}`}>{exp.frontmatter.status}</span>
            )}
            {(exp.frontmatter.results?.conjecture_year || exp.frontmatter.conjecture_year) && (
              <span class="conjecture-age">{2026 - (exp.frontmatter.results?.conjecture_year || exp.frontmatter.conjecture_year)}yr open</span>
            )}
          </div>
        </div>
        <h3>{exp.frontmatter.title}</h3>
        {exp.frontmatter.summary && (
          <p class="card-summary">{exp.frontmatter.summary.slice(0, 180)}{exp.frontmatter.summary.length > 180 ? '...' : ''}</p>
        )}
        {exp.frontmatter.results?.failures !== undefined && (
          <div class="card-result">
            <strong>{exp.frontmatter.results.failures === 0 ? 'PASS' : 'FAIL'}</strong>
            {exp.frontmatter.results.verified_range && (
              <span>— {exp.frontmatter.results.verified_range[1].toLocaleString()} verified</span>
            )}
          </div>
        )}
        <div class="card-footer-row">
          <div class="card-tags">
            {exp.frontmatter.tags?.domain?.slice(0, 3).map((t: string) => <span class="tag tag-domain">{t}</span>)}
          </div>
          {exp.frontmatter.hardware?.gpus && (
            <span class="card-hw">{exp.frontmatter.hardware.gpus.replace(/\(.*\)/, '').trim()}</span>
          )}
        </div>
      </a>
    ))}
  </section>

  <section class="connect m-reveal">
    <h2>Start Exploring</h2>
    <p class="connect-intro">
      Every experiment on this site has CUDA source code, reproduction commands, and open datasets.
      Connect an AI agent to explore the data, or dive in yourself.
    </p>

    <div class="connect-grid">
      <div class="connect-card connect-mcp">
        <h3>MCP Server</h3>
        <p>Connect Claude, Cursor, or any MCP client to query experiments, datasets, and CUDA kernels directly.</p>
        <code class="connect-url">mcp.bigcompute.science/mcp</code>
        <div class="connect-configs">
          <details>
            <summary>Claude Code</summary>
            <pre>claude mcp add bigcompute \
  --transport sse \
  https://mcp.bigcompute.science/mcp</pre>
          </details>
          <details>
            <summary>Cursor / VS Code</summary>
            <pre>&#123;"mcpServers": &#123;"bigcompute": &#123;"url": "https://mcp.bigcompute.science/mcp"&#125;&#125;&#125;</pre>
          </details>
          <details>
            <summary>Claude Desktop</summary>
            <pre>// Add to claude_desktop_config.json
&#123;"mcpServers": &#123;"bigcompute": &#123;"url": "https://mcp.bigcompute.science/mcp"&#125;&#125;&#125;</pre>
          </details>
        </div>
      </div>

      <div class="connect-card">
        <h3>Browse the Data</h3>
        <p>All datasets are on Hugging Face — free to download, no account needed.</p>
        <a href="https://huggingface.co/cahlen" class="connect-btn">Hugging Face Datasets</a>
      </div>

      <div class="connect-card">
        <h3>Run the Code</h3>
        <p>Clone the repo. Every experiment has a CUDA kernel, compile command, and test case.</p>
        <a href="https://github.com/cahlen/idontknow" class="connect-btn">GitHub Repository</a>
        <p class="connect-note">No B200 required — most kernels run on any CUDA GPU.</p>
      </div>

      <div class="connect-card">
        <h3>Contribute</h3>
        <p>Run computations on your hardware. Upload to your own HF repo. Submit a PR.</p>
        <a href="https://github.com/cahlen/idontknow/blob/main/AGENTS.md" class="connect-btn">AGENTS.md</a>
        <p class="connect-note">Open problems that need GPU time listed inside.</p>
      </div>
    </div>
  </section>

  <section class="model-showcase m-reveal">
    <h2>Research Companion Model</h2>
    <a href="https://huggingface.co/cahlen/Convergent-7B" class="model-banner-link" target="_blank">
      <img src="/images/convergent-banner.jpg" alt="Convergent-7B — research companion model for computational number theory" class="model-banner" loading="lazy" />
    </a>
    <h3 class="model-name">Convergent-7B</h3>
    <p class="model-desc">
      A QLoRA fine-tuned research companion for computational number theory. Trained on 5,729 examples from this project's experiments, CUDA kernels, and synthetic mathematical reasoning. Built on Qwen2.5-7B-Instruct, trained on an RTX 5090.
    </p>

    <div class="model-stats">
      <div class="model-stat">
        <span class="stat-number">74%</span>
        <span class="stat-label">benchmark accuracy</span>
      </div>
      <div class="model-stat">
        <span class="stat-number">5,729</span>
        <span class="stat-label">training examples</span>
      </div>
      <div class="model-stat">
        <span class="stat-number">23</span>
        <span class="stat-label">MCP tools callable</span>
      </div>
    </div>

    <ul class="model-capabilities">
      <li>Number theory reasoning — Zaremba, Ramsey, Kronecker, Cohen-Lenstra, Hausdorff dimensions</li>
      <li>CUDA kernel generation and optimization (sm_86 → sm_120)</li>
      <li>Agentic tool calling via the bigcompute.science MCP server</li>
    </ul>

    <div class="model-links">
      <a href="https://huggingface.co/cahlen/Convergent-7B" class="connect-btn" target="_blank">Model Weights</a>
      <a href="https://huggingface.co/datasets/cahlen/Convergent-7B-data" class="connect-btn" target="_blank">Training Data</a>
      <a href="https://github.com/cahlen/convergent" class="connect-btn" target="_blank">Training Code</a>
    </div>

    <pre class="model-quickstart"><code>git clone https://github.com/cahlen/convergent && cd convergent
pip install -r requirements.txt
./convergent agent -q "What are the Zaremba exceptions for {1,2,3}?"</code></pre>
  </section>

  <section class="about m-reveal">
    <h2>What is this?</h2>
    <p>
      GPU-accelerated exploration of open conjectures — Zaremba, Ramsey R(5,5), Cohen-Lenstra, Kronecker coefficients, and more. A Guerrilla Mathematics&#8482; project. Human-AI collaborative. Not peer-reviewed. All data open.
    </p>
    <p>
      Every experiment includes exact hardware specs, method, raw data, and commands to reproduce. Content is designed for both human readers and AI agents — see <a href="/llms.txt">/llms.txt</a>.
    </p>
  </section>

  <script is:inline>
  (function() {
    var reveals = document.querySelectorAll('.m-reveal');
    function onScroll() {
      var vh = window.innerHeight;
      for (var i = 0; i < reveals.length; i++) {
        var el = reveals[i];
        if (el.getBoundingClientRect().top < vh * 0.85) el.classList.add('visible');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
  </script>

  <style>
    .m-reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .m-reveal.visible { opacity: 1; transform: translateY(0); }
    .m-reveal:nth-child(2) { transition-delay: 0.05s; }
    .m-reveal:nth-child(3) { transition-delay: 0.1s; }
    .m-reveal:nth-child(4) { transition-delay: 0.15s; }
    /* ── Model Showcase ── */
    .model-showcase { margin: 4rem auto 0; max-width: var(--wide-width); padding: 0 24px; }
    .model-showcase h2 { font-family: var(--font-serif); font-size: 1.3rem; letter-spacing: -0.02em; margin-bottom: 1.2rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--rule); }
    .model-banner-link { display: block; border-radius: 8px; overflow: hidden; margin-bottom: 1.5rem; border: 1px solid var(--rule); transition: border-color 0.3s ease; }
    .model-banner-link:hover { border-color: var(--accent); }
    .model-banner { width: 100%; height: auto; display: block; }
    .model-name { font-family: var(--font-mono); font-size: 1.4rem; color: var(--accent); margin-bottom: 0.5rem; letter-spacing: -0.02em; }
    .model-desc { color: var(--ink-secondary); line-height: 1.8; margin-bottom: 1.5rem; max-width: 640px; }
    .model-stats { display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .model-stat { background: var(--panel); border: 1px solid var(--rule); border-radius: 6px; padding: 0.75rem 1.25rem; text-align: center; min-width: 120px; flex: 1; }
    .stat-number { display: block; font-family: var(--font-mono); font-size: 1.5rem; font-weight: 700; color: var(--accent-gold); line-height: 1.2; }
    .stat-label { display: block; font-family: var(--font-sans); font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }
    .model-capabilities { list-style: none; margin-bottom: 1.5rem; padding: 0; }
    .model-capabilities li { color: var(--ink-secondary); line-height: 1.7; padding-left: 1.2em; position: relative; }
    .model-capabilities li::before { content: '›'; position: absolute; left: 0; color: var(--accent); font-weight: 600; }
    .model-links { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .model-quickstart { background: var(--surface); border: 1px solid var(--rule); border-radius: 6px; padding: 1rem 1.25rem; overflow-x: auto; font-family: var(--font-mono); font-size: 0.78rem; line-height: 1.6; color: var(--ink-secondary); }
    .model-quickstart code { font-family: inherit; color: inherit; }
    @media (max-width: 600px) {
      .model-stats { flex-direction: column; }
      .model-stat { min-width: unset; }
      .model-links { flex-direction: column; }
      .model-links .connect-btn { text-align: center; }
    }

    .about h2 { font-family: var(--font-serif); font-size: 1.3rem; letter-spacing: -0.02em; margin-bottom: 0.8rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--rule); }
    .about p { color: var(--ink-secondary); line-height: 1.8; margin-bottom: 1rem; }
    .about a { color: var(--accent); text-decoration: none; border-bottom: 1px dotted color-mix(in srgb, var(--accent) 50%, transparent); }
  </style>
</Base>
