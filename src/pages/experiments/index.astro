---
import Base from '../../layouts/Base.astro';

const experiments = await Astro.glob('../../content/experiments/*.md');
const sorted = experiments.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<Base title="All Experiments">
  <h1 class="m-reveal">All Experiments</h1>
  <p class="m-reveal" style="color: var(--muted); margin-bottom: 1.5rem; font-size: 0.9rem; font-style: italic;">
    GPU-accelerated exploration of open conjectures. Every experiment has CUDA source, reproduction commands, and open data.
  </p>

  <div class="experiments-list">
    {sorted.map((exp) => (
      <a href={`/experiments/${exp.frontmatter.slug}/`} class="experiment-card">
        <div class="card-top-row">
          <time datetime={exp.frontmatter.date}>
            {new Date(exp.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
          <div class="card-badges">
            {exp.frontmatter.status && (
              <span class={`status status-${exp.frontmatter.status}`}>{exp.frontmatter.status}</span>
            )}
          </div>
        </div>
        <h3>{exp.frontmatter.title}</h3>
        <p class="card-summary">{exp.frontmatter.summary?.slice(0, 200)}{exp.frontmatter.summary?.length > 200 ? '...' : ''}</p>
        <div class="card-tags">
          {exp.frontmatter.tags?.domain?.slice(0, 4).map((t: string) => <span class="tag tag-domain">{t}</span>)}
        </div>
      </a>
    ))}
  </div>

  <script is:inline>
  (function() {
    var reveals = document.querySelectorAll('.m-reveal');
    function onScroll() {
      var vh = window.innerHeight;
      for (var i = 0; i < reveals.length; i++) {
        var el = reveals[i];
        if (el.getBoundingClientRect().top < vh * 0.85) el.classList.add('visible');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
  </script>

  <style>
    .m-reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .m-reveal.visible { opacity: 1; transform: translateY(0); }
    h1 { font-family: var(--font-serif); letter-spacing: -0.03em; }
  </style>
</Base>
