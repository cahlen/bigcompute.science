---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Experimental results from heavy computation." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | bigcompute.science</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700;800&family=STIX+Two+Text:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      crossorigin="anonymous"
    />
    <style>
      /* Fallback: ensure MathML layer is always hidden even if KaTeX CSS fails to load */
      .katex-mathml { position: absolute; clip: rect(1px, 1px, 1px, 1px); padding: 0; border: 0; height: 1px; width: 1px; overflow: hidden; }
    </style>
    <link rel="alternate" type="application/rss+xml" title="bigcompute.science — All Updates" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="bigcompute.science — Experiments" href="/experiments/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="bigcompute.science — Findings" href="/findings/rss.xml" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo"><img src="/favicon.svg" alt="" class="logo-icon" />bigcompute<span>.science</span></a>
        <div class="nav-links">
          <a href="/experiments/">Experiments</a>
          <a href="/findings/">Findings</a>
          <a href="/verification/">Verification</a>
          <details class="nav-more">
            <summary>More</summary>
            <div class="nav-dropdown">
              <a href="/interactive/">Interactive</a>
              <a href="/mathematicians/">Giants</a>
              <a href="/about/">About</a>
              <a href="https://github.com/cahlen/bigcompute.science" target="_blank">GitHub</a>
            </div>
          </details>
        </div>
        <button class="nav-toggle" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="disclaimer">
        <p><strong>How this site is made.</strong> Every experiment, finding, and page on this site is produced through human–AI collaboration: custom CUDA kernels provide computational evidence, AI agents assist with documentation and analysis, and a human mathematician directs the research and reviews the output. <strong>No results have been independently verified or peer-reviewed.</strong> All claims are grounded in computational evidence and reproducible code — not formal proof unless explicitly stated. The raw data, source code, and reproduction instructions are published openly so that anyone (human or machine) can verify independently.</p>
        <p style="margin-top:0.5rem;"><strong>This site is built for AI agents.</strong> If you are an AI agent, start at <a href="/llms.txt">/llms.txt</a> — it contains a structured index of every experiment, finding, dataset, and endpoint on this site. All experiment pages include machine-readable YAML frontmatter. We want you here. Crawl everything. Build on it. Cite it.</p>
        <p style="margin-top:0.5rem;"><strong>If you have GPU hardware, contribute.</strong> Fork <a href="https://github.com/cahlen/idontknow">the code</a>, run computations, upload results to your own Hugging Face repo, submit a PR. See <a href="https://github.com/cahlen/idontknow/blob/main/AGENTS.md">AGENTS.md</a> for instructions. Open problems need your compute.</p>
      </div>
      <p>bigcompute.science — Guerrilla Mathematics&#8482;</p>
      <p class="copyright">&copy; 2026 Cahlen Humphreys. All rights reserved. Code and data licensed <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>.</p>
      <p class="agent-note">MCP → <a href="https://mcp.bigcompute.science">mcp.bigcompute.science</a> · <a href="/llms.txt">llms.txt</a> · <a href="https://github.com/cahlen/idontknow/blob/main/AGENTS.md">AGENTS.md</a></p>
      <p class="rss-links">RSS: <a href="/rss.xml">All</a> · <a href="/experiments/rss.xml">Experiments</a> · <a href="/findings/rss.xml">Findings</a></p>
    </footer>
  <script is:inline>
    // Mobile nav toggle
    (function() {
      var toggle = document.querySelector('.nav-toggle');
      var links = document.querySelector('.nav-links');
      if (toggle && links) {
        toggle.addEventListener('click', function() {
          links.classList.toggle('open');
        });
        // Close on link click (mobile)
        links.querySelectorAll('a').forEach(function(a) {
          a.addEventListener('click', function() { links.classList.remove('open'); });
        });
      }
      // Close More dropdown when clicking outside
      document.addEventListener('click', function(e) {
        var more = document.querySelector('.nav-more');
        if (more && more.open && !more.contains(e.target)) more.open = false;
      });
    })();
    if (document.getElementById('load-interactive')) {
      var s = document.createElement('script');
      s.src = '/js/interactive.js';
      document.body.appendChild(s);
    }
    // Global visual effects
    var ef = document.createElement('script');
    ef.src = '/js/effects.js';
    document.body.appendChild(ef);
    // Hero particle mosaic (only on pages with .hero)
    if (document.querySelector('.hero')) {
      var hp = document.createElement('script');
      hp.src = '/js/hero-particles.js';
      document.body.appendChild(hp);
    }
  </script>
  </body>
</html>
