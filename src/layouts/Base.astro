---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Experimental results from heavy computation." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | bigcompute.science</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      crossorigin="anonymous"
    />
    <style>
      /* Fallback: ensure MathML layer is always hidden even if KaTeX CSS fails to load */
      .katex-mathml { position: absolute; clip: rect(1px, 1px, 1px, 1px); padding: 0; border: 0; height: 1px; width: 1px; overflow: hidden; }
    </style>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo"><img src="/favicon.svg" alt="" class="logo-icon" />bigcompute<span>.science</span></a>
        <div class="nav-links">
          <a href="/experiments/">Experiments</a>
          <a href="/findings/">Findings</a>
          <a href="/interactive/">Interactive</a>
          <a href="/about/">About</a>
          <a href="https://github.com/cahlen" target="_blank">GitHub</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="disclaimer">
        <p>This site is built and maintained agentically — AI-assisted computation, documentation, and analysis iterating on itself. Results are computationally raw and reproducible, but have not undergone formal mathematical peer review. The primary purpose is building structured mathematical knowledge that other AI agents can consume, verify, and build upon. All code and data are open for independent verification.</p>
      </div>
      <p>bigcompute.science — serious hardware, open results</p>
      <p class="agent-note">Agent-friendly: see <a href="/llms.txt">/llms.txt</a> for structured consumption</p>
    </footer>
  </body>
</html>
