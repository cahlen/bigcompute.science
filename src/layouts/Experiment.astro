---
import Base from './Base.astro';

const { frontmatter } = Astro.props;
const { title, date, author, status, hardware, tags, results } = frontmatter;
---

<Base title={title}>
  <article class="experiment">
    <div class="experiment-meta">
      <div class="meta-row">
        <time datetime={date}>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span class="author">by <a href={frontmatter.author_github}>{author}</a></span>
        {status && <span class={`status status-${status}`}>{status}</span>}
        {frontmatter.certification && (
          <span class={`cert-badge cert-${frontmatter.certification.level}`}
                title={frontmatter.certification.note}>
            {frontmatter.certification.level === 'gold' ? 'Gold' :
             frontmatter.certification.level === 'silver' ? 'Silver' :
             frontmatter.certification.level === 'bronze' ? 'Bronze' : '?'}
          </span>
        )}
      </div>

      {frontmatter.certification && (
        <details class="cert-detail">
          <summary class="cert-detail-summary">
            <span class={`cert-badge cert-${frontmatter.certification.level}`}>
              {frontmatter.certification.level.toUpperCase()}
            </span>
            <span class="cert-summary-text">
              AI Literature Audit
              {frontmatter.certification.reviews && ` \u00b7 ${frontmatter.certification.reviews} review${frontmatter.certification.reviews > 1 ? 's' : ''}`}
            </span>
            <span class="cert-expand-hint">&darr;</span>
          </summary>
          <div class="cert-expanded">
            <table class="cert-table-inner">
              <tr>
                <td class="cert-label">Verdict</td>
                <td><code>{frontmatter.certification.verdict}</code></td>
              </tr>
              <tr>
                <td class="cert-label">Reviewed by</td>
                <td>{frontmatter.certification.reviewer}</td>
              </tr>
              <tr>
                <td class="cert-label">Date</td>
                <td>{frontmatter.certification.date}</td>
              </tr>
              <tr>
                <td class="cert-label">Level</td>
                <td>
                  <span class={`cert-badge cert-${frontmatter.certification.level}`} style="font-size:0.65rem">
                    {frontmatter.certification.level.toUpperCase()}
                  </span>
                  {frontmatter.certification.level === 'gold' && ' \u2014 3+ published papers corroborate methods'}
                  {frontmatter.certification.level === 'silver' && ' \u2014 Published literature supports approach'}
                  {frontmatter.certification.level === 'bronze' && ' \u2014 Novel observation, limited literature precedent'}
                </td>
              </tr>
              {frontmatter.certification.revision_status && (
                <tr>
                  <td class="cert-label">Revisions</td>
                  <td>{frontmatter.certification.revision_status}</td>
                </tr>
              )}
            </table>

            <div class="cert-note-box">
              <p>{frontmatter.certification.note}</p>
            </div>

            <div class="cert-actions">
              <a href={`https://github.com/cahlen/idontknow/blob/main/docs/verifications/${frontmatter.slug}_peer-review.json`} target="_blank" class="cert-action-btn">Full Review</a>
              <a href="/verification/" class="cert-action-btn">About Auditing</a>
              <a href="https://github.com/cahlen/idontknow/blob/main/docs/verifications/SCHEMA.md" target="_blank" class="cert-action-btn cert-action-contribute">Add Your Audit</a>
            </div>
          </div>
        </details>
      )}

      {hardware && (
        <div class="hardware-block">
          <h4>Hardware</h4>
          <div class="hardware-specs">
            <span class="spec">{hardware.gpus}</span>
            <span class="spec">{hardware.cpus}</span>
            <span class="spec">{hardware.ram} RAM</span>
          </div>
        </div>
      )}

      {tags && (
        <div class="tags">
          {tags.domain?.map((t: string) => <span class="tag tag-domain">{t}</span>)}
          {tags.hardware?.map((t: string) => <span class="tag tag-hw">{t}</span>)}
          {tags.method?.map((t: string) => <span class="tag tag-method">{t}</span>)}
        </div>
      )}

      {results && (
        <div class="results-summary">
          <h4>Key Results</h4>
          <dl>
            {results.conjecture && <><dt>Conjecture</dt><dd>{results.conjecture}</dd></>}
            {results.verified_range && <><dt>Verified Range</dt><dd>d = {results.verified_range[0].toLocaleString()} to {results.verified_range[1].toLocaleString()}</dd></>}
            {results.failures !== undefined && <><dt>Failures</dt><dd class={results.failures === 0 ? 'result-pass' : 'result-fail'}>{results.failures}</dd></>}
            {results.llm_proofs && <><dt>LLM Proofs</dt><dd>{results.llm_proofs}</dd></>}
          </dl>
        </div>
      )}
    </div>

    <div class="experiment-content">
      <slot />
    </div>

    {frontmatter.code && (
      <div class="experiment-footer">
        <a href={frontmatter.code} class="code-link" target="_blank">View Code on GitHub</a>
      </div>
    )}
  </article>
</Base>
